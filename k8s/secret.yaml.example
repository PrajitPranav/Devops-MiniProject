# ─────────────────────────────────────────────────────────────────────────────
# HOW TO CREATE THIS SECRET (run once on your cluster):
#
#   kubectl create secret generic schemind-secrets \
#     --from-literal=MONGO_URI="mongodb+srv://user:pass@cluster.mongodb.net/schemind" \
#     --from-literal=JWT_SECRET="your_super_secret_key"
#
# DO NOT commit actual values. This file is for documentation only.
# ─────────────────────────────────────────────────────────────────────────────
apiVersion: v1
kind: Secret
metadata:
  name: schemind-secrets
type: Opaque
stringData:
  MONGO_URI: "REPLACE_WITH_YOUR_MONGO_URI"
  JWT_SECRET: "REPLACE_WITH_YOUR_JWT_SECRET"
